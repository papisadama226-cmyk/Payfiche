/* ==========================================================================
   DESIGN UNIQUE : BLEU PHOSPHORESCENT (NÉON)
   ========================================================================== */

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    /* Fond bleu nuit presque noir pour faire ressortir le néon */
    background-color: #000212;
    color: #e0faff;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
    padding: 20px;
    box-sizing: border-box;
}

/* Boîte principale de l'application */
.container {
    background: #000826;
    padding: 30px;
    border-radius: 16px;
    /* Halo lumineux bleu phosphorescent autour du bloc */
    box-shadow: 0 0 35px rgba(0, 191, 255, 0.45);
    width: 100%;
    max-width: 420px;
    border: 1px solid #142e8a;
}

/* En-tête */
.header {
    text-align: center;
    margin-bottom: 25px;
}

.header h2 {
    margin: 0;
    color: #00e5ff; /* Cyan Néon */
    font-size: 26px;
    /* Effet de lueur textuelle */
    text-shadow: 0 0 10px #00e5ff, 0 0 20px #00e5ff;
}

.header p {
    margin: 6px 0 0 0;
    color: #00bfff; /* Bleu glacier */
    font-size: 13px;
    font-style: italic;
    letter-spacing: 0.5px;
}

/* Formulaire */
.form-group {
    margin-bottom: 22px;
}

label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #00bfff;
    font-size: 14px;
    letter-spacing: 0.5px;
}

/* Configuration unifiée pour les Inputs et les Selects */
input, select {
    width: 100%;
    padding: 14px;
    border: 1px solid #00bfff;
    background-color: #000517;
    color: #fff;
    border-radius: 8px;
    box-sizing: border-box;
    font-size: 16px;
    transition: all 0.3s ease;
}

/* Style spécifique pour la liste déroulante (Wave / Orange Money) */
select {
    cursor: pointer;
    /* Personnalisation de la flèche sur certains navigateurs */
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='50' height='50' fill='%2300bfff'><path d='M10 15l15 15 15-15z'/></svg>");
    background-repeat: no-repeat;
    background-position: right 15px center;
    background-size: 15px;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    padding-right: 40px;
}

/* Effet lumineux lorsque l'utilisateur clique sur un champ */
input:focus, select:focus {
    outline: none;
    border-color: #00e5ff;
    box-shadow: 0 0 15px rgba(0, 229, 255, 0.6);
}

/* Style du champ de localisation verrouillé */
input[readonly] {
    background-color: #00030f;
    border-color: #0a1f5a;
    color: #142e8a;
    cursor: not-allowed;
    box-shadow: none;
}

/* Message d'état du GPS */
small {
    display: block;
    margin-top: 6px;
    font-size: 12px;
    color: #00e5ff;
    font-weight: 500;
    text-shadow: 0 0 5px #00e5ff;
}

/* Bouton d'action principal */
.submit-btn {
    width: 100%;
    /* Dégradé bleu électrique intense */
    background: linear-gradient(45deg, #0012ff, #0073ff);
    color: white;
    border: none;
    padding: 16px;
    font-size: 16px;
    font-weight: bold;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-top: 10px;
    /* Double halo phosphorescent sur le bouton */
    box-shadow: 0 0 15px #0012ff, 0 0 25px #0073ff;
}

.submit-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 0 20px #0012ff, 0 0 40px #0073ff;
}

.submit-btn:active:not(:disabled) {
    transform: translateY(1px);
}

/* Bouton éteint (désactivé tant que la localisation n'est pas acquise) */
.submit-btn:disabled {
    background: #0d123d;
    color: #142e8a;
    cursor: not-allowed;
    box-shadow: none;
}

/* Ajustement pour les options à l'intérieur du select */
select option {
    background-color: #000826;
    color: #fff;
}


