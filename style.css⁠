body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #1a1a2e;
    color: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
    padding: 20px;
    box-sizing: border-box;
}

.container {
    background: #162447;
    padding: 30px;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    width: 100%;
    max-width: 420px;
    border: 1px solid #1f4068;
}

.header {
    text-align: center;
    margin-bottom: 25px;
}

.header h2 {
    margin: 0;
    color: #e43f5a;
    font-size: 24px;
}

.header p {
    margin: 5px 0 0 0;
    color: #bfa393;
    font-size: 14px;
}

.form-group {
    margin-bottom: 20px;
}

label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #bfa393;
    font-size: 14px;
}

input {
    width: 100%;
    padding: 14px;
    border: 1px solid #1f4068;
    background-color: #1a1a2e;
    color: #fff;
    border-radius: 8px;
    box-sizing: border-box;
    font-size: 16px;
    transition: all 0.3s ease;
}

input:focus {
    outline: none;
    border-color: #e43f5a;
    box-shadow: 0 0 8px rgba(228, 63, 90, 0.4);
}

input[readonly] {
    background-color: #111122;
    border-color: #222;
    color: #888;
    cursor: not-allowed;
}

small {
    display: block;
    margin-top: 6px;
    font-size: 12px;
    color: #e43f5a;
    font-weight: 500;
}

.submit-btn {
    width: 100%;
    background-color: #e43f5a;
    color: white;
    border: none;
    padding: 16px;
    font-size: 16px;
    font-weight: bold;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 10px;
}

.submit-btn:hover:not(:disabled) {
    background-color: #ff4a6b;
}

.submit-btn:disabled {
    background-color: #4b5d67;
    color: #888;
    cursor: not-allowed;
}
